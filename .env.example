# Copy to .env and fill in.
#
# GARMIN_EMAIL / GARMIN_PASSWORD are NOT listed here on purpose: they are
# only needed once, interactively, for `scripts/garmin_login.py`, and
# should never be stored in this file or committed anywhere.

# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_BEARER_TOKEN=

# Public HTTPS URL this server will be reachable at behind the Synology
# reverse proxy, e.g. https://garmin.yourname.synology.me
# Required (not optional) once you set the GITHUB_* vars below.
PUBLIC_BASE_URL=

# Optional: only needed if Claude Desktop/webapp's "Add custom connector"
# UI has no field for a plain bearer token/header on your account, and
# only shows OAuth Client ID/Secret fields. In that case, create a GitHub
# OAuth App (github.com -> Settings -> Developer settings -> OAuth Apps ->
# New OAuth App) with callback URL "<PUBLIC_BASE_URL>/auth/callback", and
# fill in these three. Leave all three empty to keep using the static
# bearer token only (e.g. for Claude Desktop's local config / MCP
# Inspector / claude mcp add --header, which all support raw headers).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Your own GitHub username -- only this account will be allowed in.
ALLOWED_GITHUB_LOGIN=
